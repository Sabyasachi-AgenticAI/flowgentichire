# Supabase — https://supabase.com/dashboard/project/_/settings/api
# Use the ANON (public) key — reads are protected by RLS policies
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# VoBiz webhook — optional shared secret to verify incoming call-event webhooks.
# In VoBiz dashboard → Webhooks, set Endpoint URL to:
#   https://your-dashboard-domain.com/api/vobiz/webhook
# Then set this secret here and pass it as the "secret" query param in the URL:
#   https://your-dashboard-domain.com/api/vobiz/webhook?secret=your_secret
VOBIZ_WEBHOOK_SECRET=
